# Copy to scripts/deploy.env (gitignored) and fill in. deploy.sh sources this.
# Never commit the real values — deploy.env is in .gitignore.

# SSH target for the VM, as user@host (or user@ip).
VM_HOST=root@your-vm-host

# Absolute path to the golangserver checkout on the VM.
REMOTE_DIR=/opt/hms/mhms_final/golangserver

# Optional overrides (defaults shown):
# SSH_OPTS=-o StrictHostKeyChecking=no
# COMPOSE_FILE=docker-compose.prod.yml
# COMPOSE_DIR=$REMOTE_DIR/deployments/docker
# HEALTH_URL=http://127.0.0.1:8787/health
