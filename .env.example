APP_NAME=HotelHarmony
APP_ENV=development
LOG_LEVEL=debug
FRONTEND_URL=http://localhost:8080
CLIENT_URL=http://localhost:8080
ADMIN_URL=http://localhost:8081

HTTP_HOST=0.0.0.0
HTTP_PORT=8787

DATABASE_URL=postgres://hotel:harmony@localhost:5432/hotel_harmony?sslmode=disable
DB_MAX_OPEN_CONNS=50
DB_MAX_IDLE_CONNS=10
DB_CONN_MAX_LIFETIME=1h
DB_CONN_MAX_IDLE_TIME=15m

REDIS_URL=
REDIS_DB=0

JWT_ACCESS_SECRET=replace-with-long-random-access-secret
JWT_REFRESH_SECRET=replace-with-long-random-refresh-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h
BCRYPT_COST=12

STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PLATFORM_FEE_PERCENT=2.5

RAZORPAY_PLATFORM_KEY_ID=
RAZORPAY_PLATFORM_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

ENCRYPTION_KEY=replace-with-32-byte-hex-string

GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_MAX_TOKENS=1000

EMAIL_PROVIDER=resend
EMAIL_API_KEY=
EMAIL_FROM=noreply@hotelops.com

FRANKFURTER_BASE_URL=https://api.frankfurter.app

PLATFORM_ADMIN_EMAIL=jasmeet.15069@gmail.com
